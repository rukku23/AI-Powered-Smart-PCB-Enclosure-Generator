# ═══════════════════════════════════════════════════════════════
# EnclosureAI — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ─── AI Provider Configuration ─────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
LLM_PROVIDER=claude                      # "claude" | "ollama"

# ─── Ollama Configuration (offline mode) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── OpenSCAD Configuration ───────────────────────────────────
OPENSCAD_CLI_PATH=/usr/bin/openscad

# ─── File Management ──────────────────────────────────────────
GENERATED_FILES_DIR=/app/generated_files

# ─── Concurrency ──────────────────────────────────────────────
MAX_CONCURRENT_JOBS=5

# ─── Demo Mode ────────────────────────────────────────────────
USE_DEMO_CACHE=false

# ─── Debug Mode ───────────────────────────────────────────────
DEBUG=false
